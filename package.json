{
  "name": "agent-workspace-mcp",
  "version": "0.1.0",
  "description": "MCP server for agent-oriented TypeScript analysis, repository discovery, and web workspace context.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-workspace-mcp": "./bin/agent-workspace-mcp.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rslib build",
    "build:watch": "rslib build --watch",
    "inspect": "rslib inspect",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "smoke": "tsx src/scripts/smoke.ts",
    "test": "node --import tsx --test src/test/**/*.test.ts",
    "verify:release": "tsx src/scripts/verify-release.ts",
    "check": "npm run build && npm run test && npm run smoke -- \"./fixtures/monorepo\" \"./fixtures/monorepo/packages/app/src/index.ts\" 1 10 && npm run verify:release",
    "release:dry-run": "npm run check && npm pack --dry-run",
    "prepublishOnly": "npm run check"
  },
  "engines": {
    "node": ">=18.20.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/c0sc0s/agent-workspace-mcp.git"
  },
  "homepage": "https://github.com/c0sc0s/agent-workspace-mcp#readme",
  "bugs": {
    "url": "https://github.com/c0sc0s/agent-workspace-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "typescript",
    "code-intelligence",
    "monorepo",
    "codex"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.28.0",
    "typescript": "6.0.2",
    "zod": "4.1.11"
  },
  "devDependencies": {
    "@rslib/core": "^0.20.1",
    "@types/node": "24.5.2",
    "tsx": "4.20.6"
  }
}
