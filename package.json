{
  "name": "agent-workspace-mcp",
  "version": "0.1.0",
  "description": "MCP server for agent-oriented TypeScript analysis, repository discovery, and web workspace context.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agent-workspace-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "node --loader tsx src/index.ts",
    "smoke": "node dist/scripts/smoke.js",
    "test": "npm run build && node --eval \"require('node:fs').rmSync('dist-test', { recursive: true, force: true })\" && tsc -p tsconfig.test.json && node --test dist-test/test/**/*.test.js",
    "prepublishOnly": "npm run test"
  },
  "engines": {
    "node": ">=18.20.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/c0sc0s/agent-workspace-mcp.git"
  },
  "homepage": "https://github.com/c0sc0s/agent-workspace-mcp#readme",
  "bugs": {
    "url": "https://github.com/c0sc0s/agent-workspace-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "typescript",
    "code-intelligence",
    "monorepo",
    "codex"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.28.0",
    "typescript": "6.0.2",
    "zod": "4.1.11"
  },
  "devDependencies": {
    "@rslib/core": "^0.20.1",
    "@types/node": "24.5.2",
    "tsx": "4.20.6"
  }
}
